# Copy to project root as `.env` before `docker compose up`.
# RDS MySQL: create database `fma`, user/password, then use URL below (URL-encode special chars in password).

DATABASE_URL=mysql://appuser:CHANGE_ME_STRONG_PASSWORD@your-db.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com:3306/fma
NODE_ENV=production

# Must match JWT/session usage (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-string

# Shown in client bundle for login URL construction; use a stable app id string.
VITE_APP_ID=your-app-id

STATIC_ADMIN_PHONE=6512345678
OWNER_OPEN_ID=admin-owner-open-id

# Optional Forge / S3 features
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional: Vite client map widget (leave empty if unused)
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# Docker Compose only — host port mapped to container 3000
PUBLIC_PORT=80

# Behind ALB/HTTPS: set to 1 (default). Nested proxies: increase.
TRUST_PROXY_HOPS=1
